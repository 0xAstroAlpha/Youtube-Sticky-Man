GEMINI_API_KEY=your_gemini_api_key_here

# Model to use for semantic scene planning and surgery.
# Options (confirmed available via google-genai SDK):
#   gemini-2.0-flash              (fast, cheap — recommended)
#   gemini-2.5-flash-preview-05-20 (best Flash quality)
#   gemini-1.5-flash              (stable fallback)
#   gemini-1.5-pro                (highest quality, expensive)
#   gemini-3.1-pro-preview        (if available on your account)
GEMINI_MODEL=gemini-2.0-flash
